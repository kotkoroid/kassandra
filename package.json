{
  "name": "kassandra",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "applications/*",
    "libraries/*",
    "orchestrators/*",
    "services/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "alchemy dev",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "graph": "nx graph",
    "types:check": "nx run-many -t types:check",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint --fix",
    "lint:check": "vp lint"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@effect/platform-bun": "4.0.0-beta.66",
    "@effect/platform-node": "4.0.0-beta.66",
    "@nx/js": "22.7.1",
    "@types/bun": "1.3.13",
    "alchemy": "2.0.0-beta.40",
    "effect": "4.0.0-beta.66",
    "nx": "22.7.1",
    "typescript": "6.0.2",
    "vite-plus": "0.1.20"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
