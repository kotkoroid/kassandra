# Operating System
.DS_Store

# Dependencies
node_modules/

# Build
dist/

# TypeScript
tsbuild/
tsconfig.tsbuildinfo

# Nx
.nx/

# Alchemy
.alchemy/

# Local secrets / env
.env
.env.*
!.env.example

# Agents — ignore everything in .claude EXCEPT shared Claude Skills,
# which are repo-level architectural assets. Note: gitignore can't
# re-include a file under an ignored *directory*, so we ignore the
# contents (`.claude/*`) rather than the directory itself, then carve
# out `skills/` with a negation.
.claude/*
!.claude/skills/

# Vitest browser-mode failure artifacts
.vitest-attachments/
**/__screenshots__/
