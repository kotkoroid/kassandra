{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "erasableSyntaxOnly": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "lib": ["esnext", "dom"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@applications/game/*": ["./applications/game/*"],
      "@kassandra/simulation-domain-library": ["./libraries/domain/simulation/src/index.ts"],
      "@kassandra/protocol-foundation-library": ["./libraries/foundation/protocol/src/index.ts"],
      "@kassandra/effect-conventions-foundation-library": ["./libraries/foundation/effect-conventions/src/index.ts"],
      "@kassandra/gateway-orchestrator": ["./orchestrators/gateway/src/Gateway.ts"],
      "@kassandra/realm-service": ["./services/realm/src/Realm.ts"]
    },
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": true
  }
}
